---
import Layout from '../layouts/Layout.astro';
---

<Layout title="My Favorites | World Cup 2026">
    <link rel="stylesheet" href="/css/favorites.css" />
    
    <div class="dashboard-page">
        <a href="/" class="btn-home">&larr;Home</a>

        <h2 class="section-title" style="margin-top: 50px;">My Favorite Teams ⭐</h2>
        
        <div class="grid" id="favorites-grid">
            </div>

        <div class="empty-msg-container" id="empty-container" style="display: none;">
            <div class="empty-msg">
                <p>Your favorites list is empty!</p>
                <a href="/national-teams" class="edit-btn">Find National Teams</a>
            </div>
        </div>
    </div>

    <div id="editModal" class="modal">
        <div class="modal-content">
            <span class="close-modal">&times;</span>
            <h2 id="editTitle">Team Evaluation</h2>
            <form id="editForm">
                <input type="hidden" id="editIndex" />
                
                <label>Comments:</label>
                <textarea id="editComment" placeholder="Why is this National Team your favorite?" rows="3"></textarea>
                
                <div style="display: flex; gap: 20px; margin-top: 10px;">
                    <div style="flex: 1;">
                        <label>Rating (1-5 ⭐):</label>
                        <input type="number" id="editRating" min="1" max="5" />
                    </div>
                    <div style="flex: 1;">
                        <label>Expected Points:</label>
                        <input type="number" id="editPoints" min="0" max="9" />
                    </div>
                </div>
                
                <button type="submit" class="edit-btn" style="width: 100%; margin-top: 25px;">Update Favorite</button>
            </form>
        </div>
    </div>
</Layout>

<script is:inline>
    function renderFavorites() {
        const grid = document.getElementById('favorites-grid');
        const emptyContainer = document.getElementById('empty-container');
        const favs = JSON.parse(localStorage.getItem('wc_favorites')) || [];

        if (favs.length === 0) {
            grid.innerHTML = '';
            emptyContainer.style.display = 'flex';
            return;
        }

        emptyContainer.style.display = 'none';
        grid.innerHTML = favs.map((team, index) => `
            <div class="card">
                <div class="card-content">
                    <div class="flag-container">
                        <img src="http://localhost:3000/public/flags/${team.name}.png" 
                             class="team-flag" 
                             onerror="this.src='https://cdn-icons-png.flaticon.com/512/33/33736.png'"/>
                    </div>
                    
                    <div class="modal-info">
                        <h2>${team.name}</h2>
                        <p><strong>Group:</strong> ${team.group}</p>
                        <p><strong>Rating:</strong> ${'⭐'.repeat(team.rating || 0) || 'Not rated'}</p>
                        <p><strong>Expected Points:</strong> ${team.expectedPoints || 0}</p>
                        <p class="comment-text">"${team.comment || 'No comments yet...'}"</p>
                    </div>
                    
                    <div class="card-actions-row">
                        <button class="edit-btn" onclick="openEditModal(${index})">Edit Analysis</button>
                        <button class="reset-group-btn" onclick="removeFavorite('${team.name}')">Remove</button>
                    </div>
                </div>
            </div>
        `).join('');
    }

    const modal = document.getElementById('editModal');
    const closeBtn = document.querySelector('.close-modal');

    window.openEditModal = function(index) {
        const favs = JSON.parse(localStorage.getItem('wc_favorites')) || [];
        const team = favs[index];

        document.getElementById('editIndex').value = index;
        document.getElementById('editTitle').innerText = `${team.name} Analysis:`;
        document.getElementById('editComment').value = team.comment || "";
        document.getElementById('editRating').value = team.rating || 5;
        document.getElementById('editPoints').value = team.expectedPoints || 0;
        
        modal.style.display = "flex";
    }

    closeBtn.onclick = () => modal.style.display = "none";
    window.onclick = (e) => { if(e.target == modal) modal.style.display = "none"; }

    document.getElementById('editForm').addEventListener('submit', (e) => {
        e.preventDefault();
        const index = document.getElementById('editIndex').value;
        const favs = JSON.parse(localStorage.getItem('wc_favorites')) || [];

        favs[index].comment = document.getElementById('editComment').value;
        favs[index].rating = parseInt(document.getElementById('editRating').value);
        favs[index].expectedPoints = parseInt(document.getElementById('editPoints').value);

        localStorage.setItem('wc_favorites', JSON.stringify(favs));
        modal.style.display = "none";
        renderFavorites();
    });

    window.removeFavorite = function(name) {
        if(!confirm("Are you sure you want to remove from favorites?")) return;
        let favs = JSON.parse(localStorage.getItem('wc_favorites')) || [];
        favs = favs.filter(f => f.name !== name);
        localStorage.setItem('wc_favorites', JSON.stringify(favs));
        renderFavorites();
    }

    document.addEventListener('DOMContentLoaded', renderFavorites);
</script>